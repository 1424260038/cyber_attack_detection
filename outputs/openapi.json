          }
        },
        "type": "object",
        "required": [
          "csv_text"
        ],
        "title": "CsvDetectionRequest"
      },
      "CsvDetectionResponse": {
        "properties": {
          "total_rows": {
            "type": "integer",
            "title": "Total Rows"
          },
          "processed_rows": {
            "type": "integer",
            "title": "Processed Rows"
          },
          "used_columns": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Used Columns"
          },
          "summary": {
            "additionalProperties": {
              "type": "integer"
            },
            "type": "object",
            "title": "Summary"
          },
          "results": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Results"
          }
        },
        "type": "object",
        "required": [
          "total_rows",
          "processed_rows",
          "used_columns",
          "summary",
          "results"
        ],
        "title": "CsvDetectionResponse"
      },
